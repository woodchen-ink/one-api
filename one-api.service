# File path: /etc/systemd/system/czloapi.service
# sudo systemctl daemon-reload
# sudo systemctl start czloapi
# sudo systemctl enable czloapi
# sudo systemctl status czloapi
[Unit]
Description=CZLOapi Service
After=network.target

[Service]
User=ubuntu  # 注意修改用户名
WorkingDirectory=/path/to/czloapi  # 注意修改路径
ExecStart=/path/to/czloapi/czloapi --port 3000 --log-dir /path/to/czloapi/logs  # 注意修改路径和端口号
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
